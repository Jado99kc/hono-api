{
  "name": "my-hono-api",
  "version": "0.0.1",
  "description": "Hono API boilerplate with OpenAPI, Zod,LogLayer, and vite-node as build tool",
  "type": "module",
  "scripts": {
    "dev": "vite-node src/index.ts --watch",
    "build": "vite build --config vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/zod-openapi": "^1.2.4",
    "@loglayer/hono": "^2.1.0",
    "@loglayer/transport-pino": "^3.0.2",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "http-status-codes": "^2.3.0",
    "loglayer": "^9.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "serialize-error": "^13.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0"
  }
}